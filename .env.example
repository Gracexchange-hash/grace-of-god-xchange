# Copy this file to .env and fill in your own values before deploying.

# Port the server runs on (most hosts set this automatically)
PORT=4000

# A long random string used to sign admin login sessions.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Admin login credentials (used only the FIRST time the server runs,
# to create the admin_users row in Supabase). After that, change your
# password from the admin panel — these env values are ignored.
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# Supabase project details (Project Settings -> API in your Supabase dashboard)
# IMPORTANT: use the "service_role" key, not the "anon" key — this app
# runs only on your server, never in a browser, so it's safe here.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
